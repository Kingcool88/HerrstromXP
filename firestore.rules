rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Tillfällig utvecklingsregel: inloggade användare får läsa/skriva.
    // Byt till striktare familje-/rollregler när appen är färdigtestad.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
